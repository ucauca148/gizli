generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Supabase auth.users tablosu ile birebir eşleşen profil tablosu
model Profile {
  id        String   @id @db.Uuid // maps to auth.users.id
  email     String   @unique
  role      String   @default("ADMIN")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("profiles")
}

model Store {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  storeCode String   @unique @map("store_code")
  createdAt DateTime @default(now()) @map("created_at")

  products  Product[]
  orders    Order[]

  @@map("stores")
}

model Product {
  id                 String    @id @default(uuid()) @db.Uuid
  storeId            String    @db.Uuid @map("store_id")
  itemsatisProductId String    @unique @map("itemsatis_product_id")
  title              String
  price              Decimal   @db.Decimal(10, 2)
  status             String    @default("ACTIVE")
  lastSaleDate       DateTime? @map("last_sale_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  store              Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]

  @@map("products")
}

model Order {
  id                 String   @id @default(uuid()) @db.Uuid
  storeId            String   @db.Uuid @map("store_id")
  itemsatisOrderId   String   @unique @map("itemsatis_order_id")
  status             String   @default("PENDING") // PENDING, APPROVED, CANCELLED
  totalAmount        Decimal  @db.Decimal(10, 2) @map("total_amount")
  createdAt          DateTime @default(now()) @map("created_at")

  store              Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items              OrderItem[]

  @@index([storeId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @db.Uuid @map("order_id")
  productId   String   @db.Uuid @map("product_id")
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2) @map("unit_price")

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model WebhookEvent {
  id           String    @id @default(uuid()) @db.Uuid
  source       String    @default("ITEMSatis")
  eventType    String?   @map("event_type") // Optional until parsed
  payloadRaw   String    @map("payload_raw") @db.Text
  payloadJson  Json?     @map("payload_json")
  status       String    @default("PENDING") // PENDING, PROCESSED, FAILED, UNMAPPED
  errorMessage String?   @map("error_message") @db.Text
  receivedAt   DateTime  @default(now()) @map("received_at")
  processedAt  DateTime? @map("processed_at")

  @@index([status])
  @@index([receivedAt])
  @@map("webhook_events")
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notes")
}

model Task {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  isDone    Boolean  @default(false) @map("is_done")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tasks")
}

model Competitor {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  url       String   @unique // Mağaza profil URL'si
  platform  String   @default("itemsatis") // itemsatis, trendyol vb.
  createdAt DateTime @default(now()) @map("created_at")

  analyses  CompetitorAnalysis[]

  @@map("competitors")
}

model CompetitorAnalysis {
  id           String   @id @default(uuid()) @db.Uuid
  competitorId String   @db.Uuid @map("competitor_id")
  totalReviews Int      @default(0) @map("total_reviews") // Son 24 saatteki toplam yorum
  resultJson   Json?    @map("result_json") // Ürün bazlı detaylı dağılım
  createdAt    DateTime @default(now()) @map("created_at")

  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId])
  @@map("competitor_analyses")
}

model RankTracker {
  id            String   @id @default(uuid()) @db.Uuid
  categoryUrl   String   // Örn: itemsatis.com/valorant-hesap-satisi
  myStoreUserId String   // Kullanıcının kendi İtemSatış ID'si
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("rank_trackers")
}
